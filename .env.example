# === REQUIRED (platform won't work without these) ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === AI (needed for platform AI — skip if BYOK only) ===
ANTHROPIC_API_KEY=your-claude-api-key

# === PAYMENTS (needed for paid plans) ===
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_BUSINESS_PRICE_ID=price_...

# === EMAIL (needed for transactional emails) ===
RESEND_API_KEY=re_...
RESEND_FROM=noreply@conduitcms.io

# === SITE CONFIG ===
SITE_URL=https://conduitcms.io
SITE_DOMAIN=conduitcms.io
SITE_NAME=Conduit
NEXT_PUBLIC_APP_URL=https://conduitcms.io
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# === GOOGLE (for Search Console + Sheets import) ===
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_SHEETS_API_KEY=your-sheets-api-key

# === SOCIAL MEDIA (for auto-posting) ===
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_REFRESH_TOKEN=your-twitter-refresh-token
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token

# === NOTION (for content import) ===
NOTION_CLIENT_ID=your-notion-client-id
NOTION_CLIENT_SECRET=your-notion-client-secret

# === WEBHOOKS ===
CONDUIT_WEBHOOK_SECRET=your-webhook-signing-secret
