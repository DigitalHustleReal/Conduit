// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Broker {
  id                   String   @id @default(cuid())
  name                 String
  slug                 String   @unique
  description          String?  @db.Text
  shortDescription     String?  @db.Text
  websiteUrl           String   @map("website_url")
  logoUrl              String?  @map("logo_url")
  foundedYear          Int?     @map("founded_year")
  headquartersCountry  String?  @map("headquarters_country")
  headquartersCity     String?  @map("headquarters_city")
  minimumDeposit       Float?   @map("minimum_deposit")
  baseCurrency         String   @default("USD") @map("base_currency")
  isRegulated          Boolean  @default(false) @map("is_regulated")
  regulationBodies     String[] @map("regulation_bodies")
  accountTypes         String[] @map("account_types")
  supportedCountries   String[] @map("supported_countries")
  languagesSupported   String[] @map("languages_supported")
  featured             Boolean  @default(false)
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  fees     BrokerFee[]
  features BrokerFeature[]
  platforms BrokerPlatform[]
  ratings  BrokerRating[]
  reviews  BrokerReview[]
  affiliatePrograms AffiliateProgram[]

  @@map("broker")
}

model BrokerFee {
  id            String   @id @default(cuid())
  brokerId      String   @map("broker_id")
  feeType       String   @map("fee_type")
  instrumentType String? @map("instrument_type")
  feeAmount     Float?   @map("fee_amount")
  feeCurrency   String?  @default("USD") @map("fee_currency")
  feeStructure  String?  @map("fee_structure")
  description   String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  broker Broker @relation(fields: [brokerId], references: [id], onDelete: Cascade)

  @@map("broker_fees")
}

model BrokerFeature {
  id            String   @id @default(cuid())
  brokerId      String   @map("broker_id")
  category      String
  featureName   String   @map("feature_name")
  featureValue  String?  @map("feature_value")
  isAvailable   Boolean? @default(true) @map("is_available")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  broker Broker @relation(fields: [brokerId], references: [id], onDelete: Cascade)

  @@map("broker_features")
}

model BrokerPlatform {
  id           String   @id @default(cuid())
  brokerId     String   @map("broker_id")
  platformName String   @map("platform_name")
  platformType String   @map("platform_type")
  osSupport    String[] @map("os_support")
  features     String[]
  isPrimary    Boolean  @default(false) @map("is_primary")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  broker Broker @relation(fields: [brokerId], references: [id], onDelete: Cascade)

  @@map("broker_platforms")
}

model BrokerRating {
  id          String   @id @default(cuid())
  brokerId    String   @map("broker_id")
  category    String
  rating      Float
  reviewCount Int      @default(0) @map("review_count")
  pros        String[]
  cons        String[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  broker Broker @relation(fields: [brokerId], references: [id], onDelete: Cascade)

  @@unique([brokerId, category])
  @@map("broker_ratings")
}

model BrokerReview {
  id          String    @id @default(cuid())
  brokerId    String    @map("broker_id")
  authorName  String    @map("author_name")
  authorEmail String?   @map("author_email")
  rating      Int
  title       String?
  content     String    @db.Text
  verified    Boolean   @default(false)
  helpfulCount Int      @default(0) @map("helpful_count")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  broker Broker @relation(fields: [brokerId], references: [id], onDelete: Cascade)

  @@map("broker_reviews")
}

model AffiliateProgram {
  id        String   @id @default(cuid())
  brokerId  String   @map("broker_id")
  url       String
  commission String? @db.Text
  terms     String?  @db.Text
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  broker       Broker          @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  affiliateClicks AffiliateClick[]

  @@map("affiliate_programs")
}

model AffiliateClick {
  id                String   @id @default(cuid())
  affiliateProgramId String  @map("affiliate_program_id")
  sessionId         String?  @map("session_id")
  ipAddress         String?  @map("ip_address")
  userAgent         String?  @map("user_agent")
  referrer          String?
  utmSource         String?  @map("utm_source")
  utmMedium         String?  @map("utm_medium")
  utmCampaign       String?  @map("utm_campaign")
  createdAt         DateTime @default(now()) @map("created_at")

  affiliateProgram AffiliateProgram @relation(fields: [affiliateProgramId], references: [id], onDelete: Cascade)

  @@map("affiliate_clicks")
}

model ContentPage {
  id            String    @id @default(cuid())
  title         String
  slug          String
  content       String    @db.Text
  excerpt       String?   @db.Text
  type          String    // "blog", "guide", "page"
  status        String    @default("draft") // "draft", "published"
  metaTitle     String?   @map("meta_title")
  metaDescription String? @map("meta_description") @db.Text
  featuredImage String?   @map("featured_image")
  author        String?
  publishedAt   DateTime? @map("published_at")
  tags          String[]
  category      String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@unique([slug, type])
  @@map("content_pages")
}

model PageView {
  id        String    @id @default(cuid())
  path      String
  referrer  String?
  userAgent String?   @map("user_agent")
  ipAddress String?   @map("ip_address")
  utmSource String?   @map("utm_source")
  utmMedium String?   @map("utm_medium")
  utmCampaign String? @map("utm_campaign")
  utmTerm   String?   @map("utm_term")
  utmContent String?  @map("utm_content")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("page_views")
}

model SearchQuery {
  id          String   @id @default(cuid())
  query       String
  resultsCount Int     @default(0) @map("results_count")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("search_queries")
}

model Country {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  region    String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("countries")
}
